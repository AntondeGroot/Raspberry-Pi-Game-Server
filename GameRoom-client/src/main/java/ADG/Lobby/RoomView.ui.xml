<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:c="urn:import:com.google.gwt.user.cellview.client">
    <g:VerticalPanel width="100%" styleName="roomMainPanel">
        <g:HTMLPanel width="100%">
            <h1 ui:field="roomTitle"/>
        </g:HTMLPanel>
        <g:HTMLPanel ui:field="langSelectorRow" styleName="room-lang-row"/>
        <g:HTMLPanel ui:field="playerPanel" styleName="playerSimulation"></g:HTMLPanel>
        <g:VerticalPanel ui:field="roomPanel" styleName="full-height">
            <g:VerticalPanel styleName="bottom-aligned">
                <g:HorizontalPanel styleName="startRowPanel">
                    <g:Button ui:field="startGameButton" text="Start Game" visible="false" stylePrimaryName="confirmButton"/>
                    <g:Button ui:field="leaveRoomButton" text="Leave Room" stylePrimaryName="cancelButton"/>
                    <g:Button ui:field="deleteRoomButton" text="Delete Room" visible="false" stylePrimaryName="deleteButton"/>
                    <g:Label ui:field="startInfoLabel" styleName="startInfoLabel"/></g:HorizontalPanel>
                <g:SimplePanel styleName="custom-hr" />
                <g:TextArea ui:field="messageDisplayField" styleName="MessageDisplayField" enabled="false"/>
                <g:HorizontalPanel>
                    <g:TextBox ui:field="messageInputField" styleName="MessageInputField"/>
                    <g:Button ui:field="sendMessageButton" text="Send" styleName="sendButton"/>
                </g:HorizontalPanel>
            </g:VerticalPanel>
        </g:VerticalPanel>
    </g:VerticalPanel>
</ui:UiBinder>